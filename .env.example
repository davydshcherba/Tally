# Copy this file to .env and adjust the values for your environment.
# docker-compose.yml and the app both read it; .env itself is gitignored.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Where the app finds Postgres when running outside docker compose
# (inside compose the api service overrides the host with "postgres").
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: full connection string; takes precedence over the POSTGRES_* parts above.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Log every SQL statement the app issues (1/true/yes to enable).
# Useful for local debugging; leave off in production — it's noisy and
# can leak data into logs.
SQL_ECHO=false

# API key protecting the admin endpoints (list links, delete link).
# Clients must send it in the X-API-Key header; while unset, those
# endpoints are disabled and respond with 503.
API_KEY=change-me
