# Copy this file to .env and adjust the values for your environment.
# docker-compose.yml and the app both read it; .env itself is gitignored.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Where the app finds Postgres when running outside docker compose
# (inside compose the api service overrides the host with "postgres").
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: full connection string; takes precedence over the POSTGRES_* parts above.
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
